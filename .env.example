# Flask
FLASK_APP=app:create_app
FLASK_DEBUG=false
HOST=127.0.0.1
PORT=5000
LOG_LEVEL=INFO

# Secrets
SECRET_KEY=replace-with-a-long-random-secret-key-for-memorylens
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret-key-for-memorylens

# Database and paths
# Required local database: PostgreSQL
DATABASE_URL=postgresql://memorylens:memorylens@127.0.0.1:5432/memorylens
UPLOAD_FOLDER=C:/absolute/path/to/backend/uploads
ML_FOLDER=C:/absolute/path/to/MemoryLens/ml
VECTOR_BACKEND=pgvector
CLIP_VECTOR_DIM=512

# Frontend access
FRONTEND_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:3000,http://localhost:3000

# Upload and auth
MAX_CONTENT_LENGTH_MB=50
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=30
AUTH_RATE_LIMIT=5 per minute
RATELIMIT_STORAGE_URI=memory://
TASKS_EAGER=false
